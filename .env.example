PORT=5007
HOST=0.0.0.0
JWT_SECRET=shorja-change-me-in-production-use-long-random-string
ADMIN_USER=admin
ADMIN_PASS=admin123
BRANCH_CODE=BR001
BRANCH_NAME=ديما الحياة
SYNC_KEY=shorja-sync-key-2026-change-me
DATABASE_PATH=/app/data/shorja.db

# ربط تجهيز المخزن (بوابة المندوبين — delegate-portal)
# على VPS استخدم IP السيرفر وليس 127.0.0.1 لأن الشورجة تعمل داخل Docker
DELEGATE_PORTAL_URL=http://187.124.23.65:5005
# يجب أن يطابق SYNC_API_KEY في delegate-portal/.env (ليس SYNC_KEY الخاص بالشورجة)
DELEGATE_INTEGRATION_KEY=edari-sync-local-key-2025

# في delegate-portal: عنوان مركز الشورجة لإرسال «تم التجهيز»
# SHORJA_HUB_URL=http://187.124.23.65:5007

# Edari (الإداري) — لجلب المنتجات مباشرة من File13n
EDARI_READER_ROOT=C:\Users\Future of Technology\Documents\db\edari-reader
EDARI_MODE=tcp
EDARI_ALIAS=2025
EDARI_SERVER=127.0.0.1
EDARI_PORT=16000
EDARI_DATA_ROOT=D:\Future of Technology\EdariNX\Data
EDARI_DATABASE_PATH=D:\Future of Technology\EdariNX\Data\2025

# مزامنة الإداري — حسابات الشورجة تحت 12111 (زبائن محل الشورجه)
EDARI_SHORJA_PARENT_NUM=12111
EDARI_SHORJA_PARENT_NAME=زبائن محل الشورجه
# مزامنة الإداري — افتراضياً قراءة فقط لحماية Edari الأصلي
EDARI_WRITE_ENABLED=0
EDARI_WRITE_ACCOUNTS=0
EDARI_WRITE_INVOICES=0
EDARI_WRITE_STOCK=0
EDARI_SYNC_ACCOUNTS=1
EDARI_SYNC_EVENTS=1
EDARI_WRITE_VIA_NXSCRIPT=1
# مزامنة يدوية فقط — لا كتابة تلقائية في Edari (الترحيل من شاشة «مزامنة الإداري»)
EDARI_MANUAL_SYNC_ONLY=1
EDARI_SYNC_INTERVAL_MS=10000
NEXUS_ADMIN_URL=http://127.0.0.1:10088
EDARI_SALES_ACCOUNT_SEQ=41
EDARI_RETURNS_ACCOUNT_SEQ=42
EDARI_CASH_ACCOUNT_SEQ=316
EDARI_DISCOUNT_ACCOUNT_SEQ=132
EDARI_WALKIN_CUSTOMER_SEQ=445
EDARI_SHORJA_REMARKS=شورجة SHORJA
EDARI_SHORJA_BILL_NUM_START=9000000
# نطاق أرقام حسابات الشورجة تحت 12111 (منفصل عن أرقام الإداري اليدوية)
EDARI_SHORJA_CHILD_SUFFIX_FLOOR=9001
