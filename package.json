{
  "name": "shorja-sales",
  "version": "1.0.0",
  "description": "Shorja — نظام مبيعات الفروع مع مزامنة مركزية",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "build:admin": "cd desktop-admin && npm install && npm run build",
    "build:branch": "cd desktop-branch && npm install && npm run build",
    "build:desktop": "npm run build:admin && npm run build:branch",
    "sync:edari": "node scripts/run-edari-sync-once.js",
    "sync:edari:loop": "node scripts/run-edari-sync-loop.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "iconv-lite": "^0.7.3",
    "jsonwebtoken": "^9.0.2"
  }
}
