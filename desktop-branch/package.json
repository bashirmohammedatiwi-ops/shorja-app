{
  "name": "shorja-branch-desktop",
  "version": "1.0.14",
  "description": "شورجة — نقطة البيع (سطح المكتب)",
  "main": "main.js",
  "author": "Shorja",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.shorja.branch",
    "productName": "Shorja Branch POS",
    "directories": {
      "output": "dist-v114"
    },
    "files": [
      "main.js",
      "server-config.js",
      "server.json.example"
    ],
    "extraFiles": [
      {
        "from": "server.json.example",
        "to": "server.json"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "شورجة - نقطة البيع"
    },
    "artifactName": "Shorja-Branch-Setup-${version}.${ext}"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  }
}
